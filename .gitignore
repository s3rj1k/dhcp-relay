# Binaries for programs and plugins.
/BUILD/

# Test binary, build with `go test -c`.
/*.test

# Output of the go coverage tool.
/*.out

# Ignore local cache folder.
.cache

# Ignore common secret/sensitive artifacts to avoid accidental commits.
.env
.env.*
*.pem
*.key
*.token
*secret*
*credential*

# Ignore docker-in-docker local folder.
.docker

# Ignore the MAC policy fixture generated by the e2e harness.
e2e/macpolicy/

# Ignore the link map fixture generated by the e2e harness.
e2e/linkmap/

# Ignore the bind mounted kea control socket dir created by the e2e harness.
e2e/run-kea/

# Python caches from the e2e harness.
.venv/
__pycache__/
.pytest_cache/

# Local Claude Code project guide; intentionally untracked.
CLAUDE.md
